{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "image-boss",
	"compatibility_date": "2026-05-28",
	"compatibility_flags": ["nodejs_compat"],
	"main": "src/server/worker.js",
	"assets": {
		"directory": "dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*"]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "image-boss-db",
			"database_id": "ac88f536-6a7a-4079-b655-32a7094405c1"
		}
	],
	"ratelimits": [
		{
			"name": "API_LIMITER",
			"namespace_id": "1001",
			"simple": {
				"limit": 30,
				"period": 60
			}
		}
	]
}